{
	"name": "emoji-picker-workspace",
	"private": true,
	"version": "0.1.0",
	"packageManager": "pnpm@9.15.0",
	"workspaces": [
		"apps/*",
		"plugins/*/guest-js"
	],
	"scripts": {
		"dev": "pnpm --filter @emoji-picker/emoji-picker dev",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"format:rust:check": "cargo fmt --all -- --check",
		"lint": "pnpm --filter @emoji-picker/emoji-picker lint",
		"lint:rust": "cargo clippy --workspace --all-targets -- -D warnings",
		"typecheck": "pnpm --filter @emoji-picker/emoji-picker typecheck",
		"test": "pnpm --filter @emoji-picker/emoji-picker test",
		"test:rust": "cargo nextest run --workspace --locked --config-file nextest.toml --profile ci",
		"build": "pnpm --filter @emoji-picker/emoji-picker build",
		"build:rust": "cargo build --workspace --locked",
		"validate": "pnpm format:check && pnpm format:rust:check && pnpm lint && pnpm lint:rust && pnpm typecheck && pnpm test && pnpm test:rust && pnpm build && pnpm build:rust",
		"ci:all": "pnpm validate",
		"tauri:dev": "pnpm --filter @emoji-picker/emoji-picker tauri dev",
		"tauri:build": "pnpm --filter @emoji-picker/emoji-picker tauri build"
	},
	"devDependencies": {
		"prettier": "^3.8.1"
	}
}
