{
  "name": "emoji-picker-workspace",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.15.0",
  "workspaces": [
    "apps/*",
    "plugins/*/guest-js"
  ],
  "scripts": {
    "dev": "pnpm --filter @emoji-picker/emoji-picker dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "pnpm --filter @emoji-picker/emoji-picker lint",
    "typecheck": "pnpm --filter @emoji-picker/emoji-picker typecheck",
    "test": "pnpm --filter @emoji-picker/emoji-picker test",
    "test:rust": "cargo test --workspace --locked",
    "build": "pnpm --filter @emoji-picker/emoji-picker build",
    "build:rust": "cargo build --workspace --locked",
    "ci": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm test:rust && pnpm build && pnpm build:rust",
    "tauri:dev": "pnpm --filter @emoji-picker/emoji-picker tauri dev",
    "tauri:build": "pnpm --filter @emoji-picker/emoji-picker tauri build"
  },
  "devDependencies": {
    "prettier": "^3.8.1"
  }
}
