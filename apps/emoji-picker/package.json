{
	"name": "@emoji-picker/emoji-picker",
	"private": true,
	"version": "0.2.0",
	"description": "Emoji Nook desktop application frontend",
	"license": "(Apache-2.0 OR MIT)",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "tsc && vite build",
		"lint": "eslint .",
		"preview": "vite preview",
		"typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
		"test": "vitest run",
		"test:ci": "mkdir -p ../../test-results/emoji-picker && vitest run --reporter=default --reporter=junit --outputFile.junit=../../test-results/emoji-picker/junit.xml",
		"tauri": "tauri"
	},
	"dependencies": {
		"@tauri-apps/api": "^2",
		"@tauri-apps/plugin-autostart": "^2.5.1",
		"@tauri-apps/plugin-log": "^2",
		"@tauri-apps/plugin-opener": "^2",
		"@tauri-apps/plugin-store": "^2.4.2",
		"frimousse": "^0.3.0",
		"react": "^19.1.0",
		"react-dom": "^19.1.0",
		"tauri-plugin-xdg-portal": "workspace:*"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@tauri-apps/cli": "^2",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@types/react": "^19.1.8",
		"@types/react-dom": "^19.1.6",
		"@vitejs/plugin-react": "^4.6.0",
		"eslint": "^10.0.3",
		"eslint-plugin-react-hooks": "^7.0.1",
		"globals": "^17.4.0",
		"jsdom": "^28.1.0",
		"typescript": "~5.8.3",
		"typescript-eslint": "^8.57.0",
		"vite": "^7.0.4",
		"vitest": "^4.1.0"
	}
}
